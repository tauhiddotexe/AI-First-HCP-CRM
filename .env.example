# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_pass
POSTGRES_DB=crm_db
POSTGRES_PORT=5432

# ──────────────────────────────────────────────
# Backend (FastAPI)
# ──────────────────────────────────────────────
# In Docker: postgresql+asyncpg://crm_user:crm_pass@postgres:5432/crm_db
# Locally:   postgresql+asyncpg://crm_user:crm_pass@localhost:5432/crm_db
DATABASE_URL=postgresql+asyncpg://crm_user:crm_pass@localhost:5432/crm_db
BACKEND_PORT=8000

# ──────────────────────────────────────────────
# Groq API (required)
# ──────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ──────────────────────────────────────────────
# Frontend (React + Vite)
# ──────────────────────────────────────────────
# Prefixed with VITE_ so they are exposed to client code
# In Docker proxy mode: /api/v1
# For direct backend access: http://localhost:8000/api/v1
VITE_API_URL=/api/v1
# Used by Vite dev server proxy to route /api requests
# In Docker: http://backend:8000
# Locally:   http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000
FRONTEND_PORT=5173
